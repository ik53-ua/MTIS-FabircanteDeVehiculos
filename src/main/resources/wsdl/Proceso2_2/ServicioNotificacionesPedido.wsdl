            <wsdl:output message="tns:EnviarNotificacionPedidoResponseMessage"/>
        </wsdl:operation>
    </wsdl:portType>

    <wsdl:binding name="ServicioNotificacionesPedidoSoapBinding" type="tns:ServicioNotificacionesPedidoPortType">
        <soap:binding style="document" transport="http://schemas.xmlsoap.org/soap/http"/>
        <wsdl:operation name="EnviarNotificacionPedido">
            <soap:operation soapAction="http://mtis.org/ServicioNotificacionesPedido/EnviarNotificacionPedido"/>
            <wsdl:input><soap:body use="literal"/></wsdl:input>
            <wsdl:output><soap:body use="literal"/></wsdl:output>
        </wsdl:operation>
    </wsdl:binding>

    <wsdl:service name="ServicioNotificacionesPedido">
        <wsdl:port name="ServicioNotificacionesPedidoPort" binding="tns:ServicioNotificacionesPedidoSoapBinding">
            <soap:address location="http://localhost:8090/mtisp1/services/ServicioNotificacionesPedido"/>
