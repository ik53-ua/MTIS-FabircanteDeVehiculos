    </wsdl:binding>

    <wsdl:service name="ServicioProcesoPedidoFabricacion">
        <wsdl:port name="ServicioProcesoPedidoFabricacionPort" binding="tns:ServicioProcesoPedidoFabricacionSoapBinding">
