                <ee:set-variable variableName="wsKey">attributes.queryParams.'WSKey'</ee:set-variable>
            </ee:variables>
        </ee:transform>

        <db:select doc:name="Validar WSKey" config-ref="Database_Config">
            <db:sql>SELECT COUNT(*) AS total FROM RestKey WHERE rest_key = :wsKey</db:sql>
            <db:input-parameters><![CDATA[#[{'wsKey': vars.wsKey}]]]></db:input-parameters>
        </db:select>
        <choice doc:name="WSKey valida?">
            <when expression="#[payload[0].total == 0]">
                <ee:transform doc:name="Error WSKey">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{mensaje: "Error: WSKey invalida"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus">400</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </when>
            <otherwise>
                <db:select doc:name="Consultar componente" config-ref="Database_Config">
                    <db:sql>SELECT c.id_componente, c.nombre, c.id_proveedor FROM ComponenteFabrica c WHERE c.id_componente = :id</db:sql>
                    <db:input-parameters><![CDATA[#[{'id': vars.id}]]]></db:input-parameters>
                </db:select>
                <ee:transform doc:name="Respuesta JSON">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
if (sizeOf(payload) > 0)
  {
    componenteId: payload[0].id_componente as String,
    nombre: payload[0].nombre,
    proveedorId: payload[0].id_proveedor as String
  }
else
  {
    mensaje: "Componente no encontrado"
  }]]></ee:set-payload>
                    </ee:message>
                </ee:transform>
            </otherwise>
        </choice>
    </flow>

    <!-- ============================================ -->
