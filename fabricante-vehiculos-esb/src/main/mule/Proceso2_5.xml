                <ee:set-variable variableName="duracionMeses">payload.duracionMeses</ee:set-variable>
            </ee:variables>
        </ee:transform>
        <db:select doc:name="Validar WSKey" config-ref="Database_Config">
            <db:sql>SELECT COUNT(*) AS total FROM RestKey WHERE rest_key = :wsKey</db:sql>
            <db:input-parameters><![CDATA[#[{'wsKey': vars.wsKey}]]]></db:input-parameters>
        </db:select>
        <choice doc:name="WSKey valida?">
            <when expression="#[payload[0].total == 0]">
                <ee:transform doc:name="Error WSKey">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{mensaje: "Error: WSKey invalida"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus2_5">400</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </when>
            <otherwise>
                <db:insert doc:name="Activar garantia" config-ref="Database_Config">
                    <db:sql>INSERT INTO Garantia (vin, fecha_inicio, fecha_fin, duracion_meses, tipo_cobertura, estado) VALUES (:vehiculoId, CURDATE(), DATE_ADD(CURDATE(), INTERVAL :duracionMeses MONTH), :duracionMeses, 'COMPLETA', 'ACTIVA')</db:sql>
                    <db:input-parameters><![CDATA[#[{ 'vehiculoId': vars.vehiculoId, 'duracionMeses': vars.duracionMeses }]]]></db:input-parameters>
                </db:insert>
                <db:select doc:name="Obtener ID garantia" config-ref="Database_Config">
                    <db:sql>SELECT LAST_INSERT_ID() AS garantiaId</db:sql>
                </db:select>
                <ee:transform doc:name="Respuesta JSON">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{ garantiaId: payload[0].garantiaId as String, estado: "ACTIVA" }]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus2_5">201</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </otherwise>
        </choice>
    </flow>

    <!-- ============================================ -->
    <!-- POST /ventas - ORQUESTADOR                    -->
    <!-- Registro y Cierre de Venta Final              -->
    <!-- Orquesta: verificar vehiculo -> registrar     -->
    <!--   venta -> factura -> pago -> inventario      -->
    <!--   -> garantia                                 -->
    <!-- ============================================ -->
    <flow name="post:\ventas:application\json:Proceso2_5-config">
        <!-- 1. Extraer parametros de entrada -->
        <ee:transform doc:name="Extraer parametros">
            <ee:variables>
                <ee:set-variable variableName="wsKey">attributes.queryParams.'WSKey'</ee:set-variable>
                <ee:set-variable variableName="vehiculoId">payload.vehiculoId</ee:set-variable>
                <ee:set-variable variableName="clienteId">payload.clienteId</ee:set-variable>
                <ee:set-variable variableName="precioTotal">payload.precioTotal</ee:set-variable>
            </ee:variables>
        </ee:transform>

        <!-- 2. Validar WSKey -->
        <db:select doc:name="Validar WSKey" config-ref="Database_Config">
            <db:sql>SELECT COUNT(*) AS total FROM RestKey WHERE rest_key = :wsKey</db:sql>
            <db:input-parameters><![CDATA[#[{'wsKey': vars.wsKey}]]]></db:input-parameters>
        </db:select>
        <choice doc:name="WSKey valida?">
            <when expression="#[payload[0].total == 0]">
                <ee:transform doc:name="Error WSKey">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{mensaje: "Error: WSKey invalida"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus2_5">400</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </when>
            <otherwise>
                <!-- PASO 1: Verificar vehiculo -->
                <db:select doc:name="PASO 1 - Verificar vehiculo" config-ref="Database_Config">
                    <db:sql>SELECT vin, id_modelo, id_concesionario, estado FROM InventarioVehiculo WHERE vin = :vehiculoId</db:sql>
                    <db:input-parameters><![CDATA[#[{'vehiculoId': vars.vehiculoId}]]]></db:input-parameters>
                </db:select>
                <choice doc:name="Vehiculo disponible?">
                    <when expression="#[sizeOf(payload) == 0]">
                        <ee:transform doc:name="Error vehiculo no encontrado">
                            <ee:message>
                                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{mensaje: "Error: Vehiculo no encontrado"}]]></ee:set-payload>
                            </ee:message>
                            <ee:variables>
                                <ee:set-variable variableName="httpStatus2_5">400</ee:set-variable>
                            </ee:variables>
                        </ee:transform>
                    </when>
                    <otherwise>
                        <ee:transform doc:name="Guardar datos vehiculo">
                            <ee:variables>
                                <ee:set-variable variableName="concesionarioId">payload[0].id_concesionario</ee:set-variable>
                            </ee:variables>
                        </ee:transform>

                        <!-- PASO 2: Registrar venta -->
                        <db:insert doc:name="PASO 2 - Registrar venta" config-ref="Database_Config">
                            <db:sql>INSERT INTO Venta (id_cliente, id_concesionario, vin, precio_final, estado_venta) VALUES (:clienteId, :concesionarioId, :vehiculoId, :precioTotal, 'PENDIENTE_PAGO')</db:sql>
                            <db:input-parameters><![CDATA[#[{ 'clienteId': vars.clienteId, 'concesionarioId': vars.concesionarioId, 'vehiculoId': vars.vehiculoId, 'precioTotal': vars.precioTotal }]]]></db:input-parameters>
                        </db:insert>
                        <db:select doc:name="Obtener ID venta" config-ref="Database_Config">
                            <db:sql>SELECT MAX(id_venta) AS ventaId FROM Venta WHERE vin = :vehiculoId</db:sql>
                            <db:input-parameters><![CDATA[#[{'vehiculoId': vars.vehiculoId}]]]></db:input-parameters>
                        </db:select>
                        <ee:transform doc:name="Guardar ventaId">
                            <ee:variables>
                                <ee:set-variable variableName="ventaId">payload[0].ventaId as Number</ee:set-variable>
                            </ee:variables>
                        </ee:transform>
                        <logger level="INFO" doc:name="Log ventaId" message="VentaId creada: #[vars.ventaId]" />

                        <!-- PASO 3: Generar factura -->
                        <db:insert doc:name="PASO 3 - Generar factura" config-ref="Database_Config">
                            <db:sql>INSERT INTO Factura (id_venta, total, estado) VALUES (:ventaId, :precioTotal, 'PENDIENTE')</db:sql>
                            <db:input-parameters><![CDATA[#[{ 'ventaId': vars.ventaId, 'precioTotal': vars.precioTotal }]]]></db:input-parameters>
                        </db:insert>
                        <db:select doc:name="Obtener ID factura" config-ref="Database_Config">
                            <db:sql>SELECT MAX(id_factura) AS facturaId FROM Factura WHERE id_venta = :ventaId</db:sql>
                            <db:input-parameters><![CDATA[#[{'ventaId': vars.ventaId}]]]></db:input-parameters>
                        </db:select>
                        <ee:transform doc:name="Guardar facturaId">
                            <ee:variables>
                                <ee:set-variable variableName="facturaId">payload[0].facturaId as Number</ee:set-variable>
                            </ee:variables>
                        </ee:transform>

                        <!-- PASO 4: Registrar pago -->
                        <db:insert doc:name="PASO 4 - Registrar pago" config-ref="Database_Config">
                            <db:sql>INSERT INTO Pago (id_factura, monto, metodo_pago) VALUES (:facturaId, :precioTotal, 'TRANSFERENCIA')</db:sql>
                            <db:input-parameters><![CDATA[#[{ 'facturaId': vars.facturaId, 'precioTotal': vars.precioTotal }]]]></db:input-parameters>
                        </db:insert>
                        <db:update doc:name="Marcar factura PAGADA" config-ref="Database_Config">
                            <db:sql>UPDATE Factura SET estado = 'PAGADA' WHERE id_factura = :facturaId</db:sql>
                            <db:input-parameters><![CDATA[#[{'facturaId': vars.facturaId}]]]></db:input-parameters>
                        </db:update>
                        <db:update doc:name="Marcar venta COMPLETADA" config-ref="Database_Config">
                            <db:sql>UPDATE Venta SET estado_venta = 'COMPLETADA' WHERE id_venta = :ventaId</db:sql>
                            <db:input-parameters><![CDATA[#[{'ventaId': vars.ventaId}]]]></db:input-parameters>
                        </db:update>

                        <!-- PASO 5: Dar de baja vehiculo -->
                        <db:update doc:name="PASO 5 - Dar de baja vehiculo" config-ref="Database_Config">
                            <db:sql>UPDATE InventarioVehiculo SET estado = 'VENDIDO' WHERE vin = :vehiculoId</db:sql>
                            <db:input-parameters><![CDATA[#[{'vehiculoId': vars.vehiculoId}]]]></db:input-parameters>
                        </db:update>

                        <!-- PASO 6: Activar garantia -->
                        <db:insert doc:name="PASO 6 - Activar garantia" config-ref="Database_Config">
                            <db:sql>INSERT INTO Garantia (vin, id_venta, fecha_inicio, fecha_fin, duracion_meses, tipo_cobertura, estado) VALUES (:vehiculoId, :ventaId, CURDATE(), DATE_ADD(CURDATE(), INTERVAL 24 MONTH), 24, 'COMPLETA', 'ACTIVA')</db:sql>
                            <db:input-parameters><![CDATA[#[{ 'vehiculoId': vars.vehiculoId, 'ventaId': vars.ventaId }]]]></db:input-parameters>
                        </db:insert>

                        <!-- Respuesta final -->
                        <ee:transform doc:name="Respuesta exitosa">
                            <ee:message>
                                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{ ventaId: vars.ventaId as String, estado: "COMPLETADA" }]]></ee:set-payload>
                            </ee:message>
                            <ee:variables>
                                <ee:set-variable variableName="httpStatus2_5">201</ee:set-variable>
                            </ee:variables>
                        </ee:transform>
                    </otherwise>
                </choice>
            </otherwise>
        </choice>
    </flow>

</mule>