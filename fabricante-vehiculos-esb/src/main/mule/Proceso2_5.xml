    <!-- ============================================ -->
    <!-- CONFIGURACION APIKIT PROCESO 2.5              -->
    <!-- ============================================ -->
    <apikit:config name="Proceso2_5-config" api="Proceso2_5.raml" outboundHeadersMapName="outboundHeaders2_5" httpStatusVarName="httpStatus2_5" />

    <!-- ============================================ -->
    <!-- FLUJO PRINCIPAL - APIKit Router                -->
    <!-- ============================================ -->
    <flow name="Proceso2_5-main">
        <http:listener config-ref="HTTP_Listener_config" path="/api/ventas/v1/*">
            <http:response statusCode="#[vars.httpStatus2_5 default 200]">
                <http:headers>#[vars.outboundHeaders2_5 default {}]</http:headers>
            </http:response>
            <http:error-response statusCode="#[vars.httpStatus2_5 default 500]">
                <http:body>#[payload]</http:body>
                <http:headers>#[vars.outboundHeaders2_5 default {}]</http:headers>
            </http:error-response>
        </http:listener>
        <apikit:router config-ref="Proceso2_5-config" />
        <error-handler>
            <on-error-propagate type="APIKIT:BAD_REQUEST">
                <ee:transform doc:name="Transform Message">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{mensaje: "Bad request"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus2_5">400</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
            <on-error-propagate type="APIKIT:NOT_FOUND">
                <ee:transform doc:name="Transform Message">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{mensaje: "Resource not found"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus2_5">404</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
            <on-error-propagate type="APIKIT:METHOD_NOT_ALLOWED">
                <ee:transform doc:name="Transform Message">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{mensaje: "Method not allowed"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus2_5">405</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
            <on-error-propagate type="APIKIT:NOT_ACCEPTABLE">
                <ee:transform doc:name="Transform Message">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{mensaje: "Not acceptable"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus2_5">406</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
            <on-error-propagate type="APIKIT:UNSUPPORTED_MEDIA_TYPE">
                <ee:transform doc:name="Transform Message">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{mensaje: "Unsupported media type"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus2_5">415</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
            <on-error-propagate type="APIKIT:NOT_IMPLEMENTED">
                <ee:transform doc:name="Transform Message">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{mensaje: "Not Implemented"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus2_5">501</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
        </error-handler>
    </flow>

    <!-- ============================================ -->
    <!-- CONSOLA APIKIT PROCESO 2.5                    -->
    <!-- ============================================ -->
    <flow name="Proceso2_5-console">
        <http:listener config-ref="HTTP_Listener_config" path="/console-ventas/*">
            <http:response statusCode="#[vars.httpStatus2_5 default 200]">
                <http:headers>#[vars.outboundHeaders2_5 default {}]</http:headers>
            </http:response>
            <http:error-response statusCode="#[vars.httpStatus2_5 default 500]">
                <http:body>#[payload]</http:body>
                <http:headers>#[vars.outboundHeaders2_5 default {}]</http:headers>
            </http:error-response>
        </http:listener>
        <apikit:console config-ref="Proceso2_5-config" />
        <error-handler>
            <on-error-propagate type="APIKIT:NOT_FOUND">
                <ee:transform doc:name="Transform Message">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{mensaje: "Resource not found"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus2_5">404</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
        </error-handler>
    </flow>

    <!-- ============================================ -->
    <!-- GET /ventas/{id}                              -->
    <!-- ============================================ -->
    <flow name="get:\ventas\(id):Proceso2_5-config">
        <ee:transform doc:name="Extraer parametros">
            <ee:variables>
                <ee:set-variable variableName="id">attributes.uriParams.'id'</ee:set-variable>
                <ee:set-variable variableName="wsKey">attributes.queryParams.'WSKey'</ee:set-variable>
            </ee:variables>
        </ee:transform>
        <db:select doc:name="Validar WSKey" config-ref="Database_Config">
            <db:sql>SELECT COUNT(*) AS total FROM RestKey WHERE rest_key = :wsKey</db:sql>
            <db:input-parameters><![CDATA[#[{'wsKey': vars.wsKey}]]]></db:input-parameters>
        </db:select>
        <choice doc:name="WSKey valida?">
            <when expression="#[payload[0].total == 0]">
                <ee:transform doc:name="Error WSKey">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{mensaje: "Error: WSKey invalida"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus2_5">400</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </when>
            <otherwise>
                <db:select doc:name="Consultar venta" config-ref="Database_Config">
                    <db:sql>SELECT id_venta, estado_venta FROM Venta WHERE id_venta = :id</db:sql>
                    <db:input-parameters><![CDATA[#[{'id': vars.id}]]]></db:input-parameters>
                </db:select>
                <ee:transform doc:name="Respuesta JSON">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
if (sizeOf(payload) > 0)
  { ventaId: payload[0].id_venta as String, estado: payload[0].estado_venta }
else
  { mensaje: "Venta no encontrada" }]]></ee:set-payload>
                    </ee:message>
                </ee:transform>
            </otherwise>
        </choice>
    </flow>

