            <wsdl:output message="tns:ValidarConfiguracionResponseMessage"/>
        </wsdl:operation>
    </wsdl:portType>

    <wsdl:binding name="ServicioConfiguracionesVehiculoSoapBinding" type="tns:ServicioConfiguracionesVehiculoPortType">
        <soap:binding style="document" transport="http://schemas.xmlsoap.org/soap/http"/>
        <wsdl:operation name="ValidarConfiguracion">
            <soap:operation soapAction="http://mtis.org/ServicioConfiguracionesVehiculo/ValidarConfiguracion"/>
            <wsdl:input><soap:body use="literal"/></wsdl:input>
            <wsdl:output><soap:body use="literal"/></wsdl:output>
        </wsdl:operation>
    </wsdl:binding>

    <wsdl:service name="ServicioConfiguracionesVehiculo">
        <wsdl:port name="ServicioConfiguracionesVehiculoPort" binding="tns:ServicioConfiguracionesVehiculoSoapBinding">
            <soap:address location="http://localhost:8090/mtisp1/services/ServicioConfiguracionesVehiculo"/>
