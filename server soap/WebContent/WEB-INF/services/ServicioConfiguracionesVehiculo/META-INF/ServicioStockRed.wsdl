      <soap:operation soapAction="http://mtis.org/ServicioStockRed/ConsultarStockRed"/>
      <wsdl:input>
        <soap:body use="literal"/>
      </wsdl:input>
      <wsdl:output>
        <soap:body use="literal"/>
