{
  "info": {
    "_postman_id": "fabricante-vehiculos-api",
    "name": "Fabricante de Vehículos API",
    "description": "Colección completa para probar la API REST unificada del fabricante de vehículos",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 Autenticación",
      "item": [
        {
          "name": "WSKey disponibles en BD",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/hello",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["hello"]
            },
            "description": "WSKey válidos en la base de datos (tabla RestKey):\n- '1234'\n- 'admin-rest-key'\n\nUsa cualquiera de estos en el header 'x-api-key' para autenticarte"
          }
        }
      ]
    },
    {
      "name": "✅ GET - Componentes (Proceso 2.4)",
      "item": [
        {
          "name": "Obtener componente por ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "1234",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/produccion/componentes/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "produccion", "componentes", "1"]
            },
            "description": "Obtener detalles de un componente\n\nComponentes disponibles:\n- ID 1: Motor Diesel 2.0 (4500€)\n- ID 2: Batería Principal 150kW (6200€)\n- ID 3: Motor Gasolina 1.8 (3800€)\n- ID 4: Motor Diesel 3.0 (5500€)\n- ID 5: Chasis SUV (3200€)\n- ID 6: Chasis Urbano (2100€)"
          }
        }
      ]
    },
    {
