    {
      "name": "🚫 Errores a probar",
      "item": [
        {
          "name": "SIN WSKey - debe devolver 401",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/produccion/componentes/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "produccion", "componentes", "1"]
            },
            "description": "Esta solicitud debe fallar porque no incluye el header x-api-key\n\nRespuesta esperada:\n- Código: 401\n- Mensaje: 'Unauthorized - WSKey requerido en header x-api-key'"
          }
        },
        {
          "name": "WSKey inválido - debe devolver 403",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "wskey-invalido-xyz",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/produccion/componentes/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "produccion", "componentes", "1"]
            },
            "description": "Esta solicitud debe fallar porque el WSKey no existe en la BD\n\nRespuesta esperada:\n- Código: 403\n- Mensaje: 'Forbidden - WSKey inválido'"
          }
        },
        {
          "name": "Componente no existe - debe devolver 404",
          "request": {
            "method": "GET",
            "header": [
