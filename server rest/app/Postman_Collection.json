    {
      "name": "⏳ POST - Crear Pedido de Compra (Proceso 2.4)",
      "item": [
        {
          "name": "Crear pedido de compra",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "1234",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"componenteId\": 2,\n  \"cantidadRequerida\": 10\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/produccion/pedidosCompra",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "produccion", "pedidosCompra"]
            },
            "description": "Crear un nuevo pedido de compra\n\nCampos requeridos:\n- componenteId (INT): ID del componente\n- cantidadRequerida (INT): Cantidad a solicitar\n\nEjemplos:\n1. {\"componenteId\": 2, \"cantidadRequerida\": 10}\n2. {\"componenteId\": 6, \"cantidadRequerida\": 5}"
          }
        },
        {
          "name": "Obtener pedido de compra",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "1234",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/produccion/pedidosCompra/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "produccion", "pedidosCompra", "1"]
            },
            "description": "Obtener detalles de un pedido de compra existente"
          }
        }
      ]
    },
    {
      "name": "⏳ POST - Ventas (Proceso 2.5)",
      "item": [
        {
